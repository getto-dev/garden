// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Категории культур (овощи, цветы, плодово-ягодные, зелень)
model Category {
  id          String     @id @default(cuid())
  name        String     // Название категории
  slug        String     @unique // URL-slug
  icon        String     // Иконка (emoji или название)
  description String?    // Описание категории
  order       Int        @default(0) // Порядок отображения
  cultures    Culture[]  // Культуры в категории
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// Культуры (растения)
model Culture {
  id              String    @id @default(cuid())
  name            String    // Название
  slug            String    @unique // URL-slug
  categoryId      String    // ID категории
  category        Category  @relation(fields: [categoryId], references: [id])
  image           String?   // Изображение
  description     String?   // Краткое описание
  history         String?   // История появления
  plantingTime    String?   // Когда сажать
  careTips        String?   // Советы по уходу
  watering        String?   // Полив
  fertilizing     String?   // Удобрение
  harvesting      String?   // Сбор урожая
  storage         String?   // Хранение
  goodNeighbors   String?   // Хорошие соседи
  badNeighbors    String?   // Плохие соседи
  diseases        Disease[] // Болезни
  pests           Pest[]    // Вредители
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Статьи
model Article {
  id          String       @id @default(cuid())
  title       String       // Заголовок
  slug        String       @unique // URL-slug
  category    String       // Категория (уход, вредители, болезни и т.д.)
  image       String?      // Изображение
  excerpt     String?      // Краткое описание
  content     String       // Содержание (markdown)
  tableOfContents String?  // Оглавление (JSON)
  tags        String?      // Теги (через запятую)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// Болезни
model Disease {
  id          String     @id @default(cuid())
  name        String     // Название
  slug        String     @unique
  type        String     // Тип (грибковая, вирусная, бактериальная)
  image       String?    // Изображение
  description String?    // Описание
  symptoms    String?    // Симптомы
  causes      String?    // Причины
  treatment   String?    // Лечение
  prevention  String?    // Профилактика
  cultures    Culture[]  // Культуры, которые поражает
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// Вредители
model Pest {
  id          String     @id @default(cuid())
  name        String     // Название
  slug        String     @unique
  image       String?    // Изображение
  description String?    // Описание
  damage      String?    // Наносимый вред
  signs       String?    // Признаки появления
  control     String?    // Методы борьбы
  prevention  String?    // Профилактика
  cultures    Culture[]  // Культуры, которые поражает
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// Лунный календарь (предрасчитанные данные)
model MoonCalendar {
  id            String   @id @default(cuid())
  date          String   @unique // YYYY-MM-DD
  year          Int      // Год
  month         Int      // Месяц
  day           Int      // День
  moonPhase     String   // Фаза луны (new, waxing, full, waning)
  moonPhaseName String   // Название фазы на русском
  moonDay       Int      // Лунный день
  zodiacSign    String   // Знак зодиака
  zodiacElement String   // Стихия знака
  isGoodForSowing    Boolean @default(false) // Благоприятно для посева
  isGoodForPlanting  Boolean @default(false) // Благоприятно для посадки
  isGoodForTransplanting Boolean @default(false) // Благоприятно для пересадки
  isGoodForWatering  Boolean @default(false) // Благоприятно для полива
  isGoodForFertilizing Boolean @default(false) // Благоприятно для удобрения
  isGoodForPruning   Boolean @default(false) // Благоприятно для обрезки
  isGoodForHarvesting Boolean @default(false) // Благоприятно для сбора урожая
  isGoodForSoilWork  Boolean @default(false) // Благоприятно для обработки почвы
  isForbidden        Boolean @default(false) // Запрещённый день
  recommendation String? // Рекомендации
  createdAt     DateTime @default(now())
}

// Благоприятные дни для конкретных культур
model FavorableDays {
  id          String   @id @default(cuid())
  cultureName String   // Название культуры
  month       Int      // Месяц
  year        Int      // Год
  goodDays    String   // Благоприятные дни (через запятую)
  badDays     String   // Неблагоприятные дни (через запятую)
  createdAt   DateTime @default(now())
}
